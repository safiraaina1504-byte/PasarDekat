<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- HEADER -->

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#00B140"
        android:padding="16dp">

        <!-- Tombol Keluar -->

        <LinearLayout
            android:id="@+id/btnKeluar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_back"
                android:tint="@android:color/white"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Keluar"
                android:textColor="@android:color/white"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Keranjang -->

        <FrameLayout
            android:id="@+id/layoutCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true">

            <ImageView
                android:id="@+id/btnKeranjang"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_cart"
                android:tint="@android:color/white"/>

            <TextView
                android:id="@+id/txtBadge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="end"
                android:background="@drawable/bg_badge"
                android:gravity="center"
                android:text="0"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold"/>
        </FrameLayout>

        <!-- Sapaan -->

        <TextView
            android:id="@+id/txtHello"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/btnKeluar"
            android:layout_marginTop="22dp"
            android:text="Selamat Belanja! 👋"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtHello"
            android:text="Cari produk segar hari ini"
            android:textColor="@android:color/white"
            android:textSize="13sp"/>

        <!-- Search -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_below="@id/txtSub"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="25dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search"
                    android:tint="#808080"/>

                <EditText
                    android:id="@+id/etCari"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Cari produk..."
                    android:paddingStart="10dp"
                    android:textColor="#000"
                    android:textColorHint="#888"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </RelativeLayout>

    <!-- CARD MENU -->

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="-18dp"
        android:layout_marginHorizontal="10dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Tab -->

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                app:tabIndicatorColor="#00B140"
                app:tabIndicatorHeight="3dp"
                app:tabSelectedTextColor="#00B140"
                app:tabTextColor="#777777">

                <com.google.android.material.tabs.TabItem
                    android:text="Belanja"/>

                <com.google.android.material.tabs.TabItem
                    android:text="Toko"/>

                <com.google.android.material.tabs.TabItem
                    android:text="Pesanan"/>

            </com.google.android.material.tabs.TabLayout>

            <!-- RecyclerView -->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvData"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="8dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>