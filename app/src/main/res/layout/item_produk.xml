<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="15dp"
    app:cardElevation="3dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:padding="10dp">

        <ImageView
            android:id="@+id/imgProduk"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_centerVertical="true"
            android:background="#EEEEEE"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"/>

        <TextView
            android:id="@+id/txtNamaProduk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/imgProduk"
            android:layout_marginStart="12dp"
            android:text="Nama Produk"
            android:textStyle="bold"
            android:textSize="17sp"
            android:textColor="#000"/>

        <TextView
            android:id="@+id/txtNamaToko"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtNamaProduk"
            android:layout_toEndOf="@id/imgProduk"
            android:layout_marginStart="12dp"
            android:layout_marginTop="3dp"
            android:text="Nama Toko"
            android:textColor="#757575"/>

        <TextView
            android:id="@+id/txtHarga"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtNamaToko"
            android:layout_toEndOf="@id/imgProduk"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            android:text="Rp25.000 / KG"
            android:textColor="#00B140"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtStok"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtHarga"
            android:layout_toEndOf="@id/imgProduk"
            android:layout_marginStart="12dp"
            android:layout_marginTop="3dp"
            android:text="Stok : 20 KG"
            android:textColor="#757575"
            android:textSize="12sp"/>

        <ImageButton
            android:id="@+id/btnTambah"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_circle_green"
            android:padding="8dp"
            android:src="@android:drawable/ic_input_add"
            android:tint="@android:color/white"/>

    </RelativeLayout>

</androidx.cardview.widget.CardView>